<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:scrollbars="none"
    android:paddingStart="@dimen/screen_content_horizontal"
    android:paddingTop="@dimen/prayer_book_offset_below_app_bar"
    android:paddingEnd="@dimen/screen_content_horizontal"
    android:paddingBottom="@dimen/prayer_book_screen_padding_bottom"
    tools:context=".ui.scripture.ScriptureChaptersFragment">

    <LinearLayout
        android:id="@+id/layout_scripture_chapters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />
</ScrollView>
