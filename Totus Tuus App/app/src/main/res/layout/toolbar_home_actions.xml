<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/toolbar_actions_strip_height"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    tools:ignore="RtlSymmetry">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/button_home_settings"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/menu_settings"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_settings_black_24dp"
        app:tint="?attr/totusColorTextPrimary" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/button_home_theme"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/settings_color_scheme_section_title"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_color_scheme_24"
        app:tint="?attr/totusColorTextPrimary" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/button_home_about"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/menu_slideshow"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_info_black_24dp"
        app:tint="?attr/totusColorTextPrimary" />
</LinearLayout>
