<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:clipToPadding="false"
    android:paddingStart="@dimen/screen_content_horizontal"
    android:paddingTop="@dimen/prayer_book_offset_below_app_bar"
    android:paddingEnd="@dimen/screen_content_horizontal"
    android:paddingBottom="@dimen/prayer_book_screen_padding_bottom"
    android:scrollbars="none"
    tools:context=".ui.scripture.ScriptureReadingPlanFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_plan_intro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
            app:cardCornerRadius="@dimen/reading_plan_hero_corner"
            app:cardElevation="0dp"
            app:strokeColor="@color/brand_totus_gold"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/prayer_card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_reading_plan_icon_circle">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_calendar_today_24"
                            app:tint="?attr/totusColorTextPrimary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/text_plan_intro_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/scripture_reading_plan_title"
                            android:textColor="?attr/totusColorTextPrimary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/text_plan_intro_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/scripture_reading_plan_entry_hint"
                            android:textColor="?attr/totusColorTextTertiary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_plan_intro_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingMultiplier="1.15"
                    android:text="@string/scripture_reading_plan_linear_activation_hint"
                    android:textColor="?attr/totusColorTextSecondary"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_plan_start"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/scripture_reading_plan_start"
                    android:textColor="#2B2117"
                    app:backgroundTint="@color/brand_totus_gold"
                    app:cornerRadius="10dp"
                    app:rippleColor="?attr/totusColorRipple" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layout_plan_active"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reading_plan_hero"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_plan_today_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_plan_today_badge"
                    android:paddingStart="12dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="4dp"
                    android:text="@string/scripture_reading_plan_today_badge"
                    android:textAllCaps="true"
                    android:textColor="?attr/totusColorBgPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_plan_day_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:textColor="@color/brand_totus_gold"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        tools:text="1" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/scripture_reading_plan_day_label"
                            android:textColor="?attr/totusColorTextSecondary"
                            android:textSize="14sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/text_plan_day_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="?attr/totusColorTextTertiary"
                            android:textSize="13sp"
                            tools:text="з 365 у плане" />
                    </LinearLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_plan_days"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="365"
                    android:progressTint="@color/brand_totus_gold"
                    android:progressBackgroundTint="?attr/totusColorSurfaceStroke"
                    tools:progress="42" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_plan_progress_year"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="?attr/totusColorTextSecondary"
                    android:textSize="14sp"
                    tools:text="Выканана дзён: 10 з 365" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_plan_prev_day"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/scripture_reading_plan_prev_day_a11y"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_chevron_left_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/brand_totus_gold"
                        app:rippleColor="?attr/totusColorRipple"
                        app:strokeColor="?attr/totusColorSurfaceStroke" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_plan_next_day"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/scripture_reading_plan_next_day_a11y"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_chevron_right_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/brand_totus_gold"
                        app:rippleColor="?attr/totusColorRipple"
                        app:strokeColor="?attr/totusColorSurfaceStroke" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_plan_toggle_done"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/scripture_reading_plan_mark_done"
                    android:textColor="?attr/totusColorTextPrimary"
                    app:cornerRadius="10dp"
                    app:rippleColor="?attr/totusColorRipple"
                    app:strokeColor="@color/brand_totus_gold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_plan_pause_resume"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:text="@string/scripture_reading_plan_pause_reminders"
                        android:textColor="?attr/totusColorTextSecondary"
                        app:rippleColor="?attr/totusColorRipple" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_plan_decline"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text="@string/scripture_reading_plan_decline"
                        android:textColor="?attr/totusColorTextError"
                        app:rippleColor="?attr/totusColorRipple" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_plan_readings_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/prayer_book_block_gap"
                android:letterSpacing="0.02"
                android:text="@string/scripture_reading_plan_today_chapters"
                android:textAllCaps="true"
                android:textColor="@color/brand_totus_gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layout_plan_readings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_plan_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/prayer_book_block_gap"
                android:gravity="center"
                android:padding="@dimen/prayer_card_padding"
                android:text="@string/scripture_reading_plan_no_data"
                android:textColor="?attr/totusColorTextSecondary"
                android:textSize="15sp"
                android:visibility="gone"
                tools:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
