<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_content_horizontal"
    android:paddingTop="@dimen/prayer_book_screen_padding_top"
    android:paddingEnd="@dimen/screen_content_horizontal"
    android:paddingBottom="@dimen/prayer_book_screen_padding_bottom"
    tools:context=".ui.songbook.SongbookListFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_songbook_search_entry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/prayer_book_block_gap"
        android:layout_marginBottom="@dimen/prayer_list_item_gap"
        android:background="@drawable/bg_scripture_book_row"
        android:clickable="true"
        android:contentDescription="@string/songbook_search_title"
        android:focusable="true"
        android:minHeight="@dimen/scripture_book_row_min_height"
        android:paddingStart="@dimen/scripture_book_row_padding_horizontal"
        android:paddingTop="@dimen/scripture_book_row_padding_vertical"
        android:paddingEnd="@dimen/scripture_book_row_padding_horizontal"
        android:paddingBottom="@dimen/scripture_book_row_padding_vertical">

        <ImageView
            android:id="@+id/image_songbook_search_entry"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_search_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/totusColorTextSecondary" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_songbook_search_entry_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/songbook_search_title"
            android:textColor="?attr/totusColorTextPrimary"
            android:textSize="17sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/image_songbook_search_entry_chevron"
            app:layout_constraintStart_toEndOf="@id/image_songbook_search_entry"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/image_songbook_search_entry_chevron"
            android:layout_width="@dimen/scripture_book_row_chevron_size"
            android:layout_height="@dimen/scripture_book_row_chevron_size"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_chevron_right_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/totusColorTextTertiary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_kantaral_today_entry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="@dimen/prayer_list_item_gap"
        android:background="@drawable/bg_scripture_book_row"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="@dimen/scripture_book_row_min_height"
        android:paddingStart="@dimen/scripture_book_row_padding_horizontal"
        android:paddingTop="@dimen/scripture_book_row_padding_vertical"
        android:paddingEnd="@dimen/scripture_book_row_padding_horizontal"
        android:paddingBottom="@dimen/scripture_book_row_padding_vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/image_kantaral_today_info"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_home_info_circle"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_info_black_24dp"
            android:tint="@android:color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layout_kantaral_today_texts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/image_kantaral_today_chevron"
            app:layout_constraintStart_toEndOf="@id/image_kantaral_today_info"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_kantaral_today_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/kantaral_today_title"
                android:textColor="?attr/totusColorTextSecondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_kantaral_today_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="@string/kantaral_today_loading"
                android:textColor="?attr/totusColorTextPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/image_kantaral_today_chevron"
            android:layout_width="@dimen/scripture_book_row_chevron_size"
            android:layout_height="@dimen/scripture_book_row_chevron_size"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_chevron_right_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/totusColorTextTertiary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_songbook_categories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="@dimen/prayer_book_recycler_padding_bottom"
            android:scrollbars="none" />

        <TextView
            android:id="@+id/text_songbook_empty_center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:padding="@dimen/prayer_card_padding"
            android:textAlignment="gravity"
            android:textColor="?attr/totusColorTextSecondary"
            android:visibility="gone"
            tools:text="@string/songbook_empty"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/layout_kantaral_loading_center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient_dark"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/prayer_card_padding"
            android:visibility="gone"
            tools:visibility="gone">

            <ProgressBar
                android:id="@+id/progress_kantaral_loading_center"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:indeterminateTint="?attr/totusColorTextSecondary"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progress_kantaral_loading_horizontal"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:indeterminateTint="?attr/totusColorTextSecondary"
                android:progressTint="?attr/totusColorTextSecondary"
                android:progressBackgroundTint="?attr/totusColorSurfaceStroke"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/text_kantaral_loading_center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/kantaral_loading"
                android:textAlignment="gravity"
                android:textColor="?attr/totusColorTextSecondary" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
