<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:scrollbars="none"
    android:paddingStart="@dimen/screen_content_horizontal"
    android:paddingTop="@dimen/prayer_book_screen_padding_top"
    android:paddingEnd="@dimen/screen_content_horizontal"
    android:paddingBottom="@dimen/prayer_book_screen_padding_bottom"
    tools:context=".ui.scripture.ScriptureCompareFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layout_scripture_compare_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_banner"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/prayer_book_banner_padding"
            android:paddingTop="10dp"
            android:paddingEnd="8dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/text_scripture_compare_hint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/scripture_compare_hint"
                android:textColor="?attr/totusColorTextSecondary"
                android:textSize="@dimen/text_banner_message" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/button_scripture_compare_hide_hint"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/scripture_compare_hide_hint"
                android:padding="8dp"
                android:src="@drawable/ic_close_24"
                app:tint="?attr/totusColorTextSecondary" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
            app:cardCornerRadius="@dimen/prayer_card_corner"
            app:cardElevation="0dp"
            app:strokeColor="?attr/totusColorSurfaceStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/prayer_card_padding">

                <LinearLayout
                    android:id="@+id/layout_compare_translations_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_compare_translations_section_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/scripture_compare_select_translations"
                        android:textColor="?attr/totusColorTextPrimary"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/image_compare_translations_expand"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/scripture_compare_expand_translations"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="?attr/totusColorTextSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_compare_translations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text_scripture_compare_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            android:gravity="center"
            android:padding="@dimen/prayer_card_padding"
            android:text="@string/scripture_compare_empty"
            android:textColor="?attr/totusColorTextSecondary"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_compare_verses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
