<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.slideshow.SlideshowFragment">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
        app:cardCornerRadius="@dimen/prayer_card_corner"
        app:strokeColor="?attr/totusColorSurfaceStroke"
        app:strokeWidth="1dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/info_screen_intro_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/info_screen_block_spacing"
                android:lineSpacingExtra="4dp"
                android:lineSpacingMultiplier="1.08"
                android:text="@string/info_screen_intro"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textColor="?attr/totusColorTextSecondary" />

            <TextView
                android:id="@+id/info_screen_contact_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/info_screen_block_spacing"
                android:autoLink="email"
                android:lineSpacingExtra="4dp"
                android:lineSpacingMultiplier="1.08"
                android:linksClickable="true"
                android:text="@string/info_screen_contact"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textColor="?attr/totusColorTextSecondary"
                android:textColorLink="?attr/totusColorTextPrimary" />

            <TextView
                android:id="@+id/info_screen_web_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/info_screen_block_spacing"
                android:autoLink="web"
                android:lineSpacingExtra="4dp"
                android:lineSpacingMultiplier="1.08"
                android:linksClickable="true"
                android:text="@string/info_screen_web"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textColor="?attr/totusColorTextSecondary"
                android:textColorLink="?attr/totusColorTextPrimary" />

            <TextView
                android:id="@+id/text_app_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:lineSpacingMultiplier="1.08"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textColor="?attr/totusColorTextSecondary"
                tools:text="Версія: v1.1.0" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>