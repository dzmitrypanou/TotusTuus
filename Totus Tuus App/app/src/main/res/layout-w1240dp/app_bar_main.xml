<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:theme="@style/Theme.CatholicPrayerBookBy.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_min_height_extended"
            android:gravity="center_vertical"
            android:minHeight="@dimen/toolbar_min_height_extended"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingEnd="@dimen/toolbar_end_inset_actions"
            android:background="?attr/colorPrimary"
            app:contentInsetEnd="0dp"
            app:contentInsetEndWithActions="0dp"
            app:popupTheme="@style/Theme.CatholicPrayerBookBy.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <include
        android:id="@+id/content_main"
        layout="@layout/content_main" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>