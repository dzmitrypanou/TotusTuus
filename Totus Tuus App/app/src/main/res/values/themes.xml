<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CatholicPrayerBookBy" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:scrollbars">none</item>
        <item name="recyclerViewStyle">@style/Widget.CatholicPrayerBookBy.RecyclerView</item>
        <item name="android:listPreferredItemHeight">@dimen/list_menu_row_min_height</item>
        <item name="android:listPreferredItemHeightSmall">@dimen/list_menu_row_min_height</item>
        <item name="navigationViewStyle">@style/Widget.CatholicPrayerBookBy.NavigationView</item>
        <item name="totusColorBgPrimary">
        <item name="totusColorBgSecondary">
        <item name="totusColorSurface">
        <item name="totusColorSurfaceElevated">
        <item name="totusColorSurfaceStroke">
        <item name="totusColorTextPrimary">
        <item name="totusColorTextSecondary">
        <item name="totusColorTextTertiary">
        <item name="totusColorTextError">
        <item name="totusColorRipple">
        <item name="totusColorToolbar">
        <item name="totusColorToolbarVariant">
        <item name="totusColorScriptureHighlightFill">
        <item name="totusColorScriptureHighlightStroke">
        <item name="colorPrimary">?attr/totusColorToolbar</item>
        <item name="colorPrimaryVariant">?attr/totusColorToolbarVariant</item>
        <item name="colorOnPrimary">?attr/totusColorTextPrimary</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">?attr/totusColorTextPrimary</item>
        <item name="colorSurface">?attr/totusColorSurface</item>
        <item name="colorOnSurface">?attr/totusColorTextPrimary</item>
        <item name="android:textColorPrimary">?attr/totusColorTextPrimary</item>
        <item name="android:textColorSecondary">?attr/totusColorTextSecondary</item>

        <item name="android:textColorHighlight">?attr/totusColorRipple</item>
        <item name="android:colorControlHighlight">?attr/totusColorRipple</item>
        <item name="colorControlHighlight">?attr/totusColorRipple</item>
        <item name="android:windowBackground">@drawable/bg_gradient_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>

        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.CatholicPrayerBookBy.NoActionBar" parent="Theme.CatholicPrayerBookBy">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.CatholicPrayerBookBy.NoActionBar.White" parent="Theme.CatholicPrayerBookBy.NoActionBar">
        <item name="totusColorBgPrimary">
        <item name="totusColorBgSecondary">
        <item name="totusColorSurface">
        <item name="totusColorSurfaceElevated">
        <item name="totusColorSurfaceStroke">
        <item name="totusColorTextPrimary">
        <item name="totusColorTextSecondary">
        <item name="totusColorTextTertiary">
        <item name="totusColorTextError">
        <item name="totusColorRipple">
        <item name="totusColorToolbar">
        <item name="totusColorToolbarVariant">
        <item name="totusColorScriptureHighlightFill">
        <item name="totusColorScriptureHighlightStroke">
    </style>

    <style name="Theme.CatholicPrayerBookBy.NoActionBar.Dark" parent="Theme.CatholicPrayerBookBy.NoActionBar">
        <item name="totusColorBgPrimary">
        <item name="totusColorBgSecondary">
        <item name="totusColorSurface">
        <item name="totusColorSurfaceElevated">
        <item name="totusColorSurfaceStroke">
        <item name="totusColorTextPrimary">
        <item name="totusColorTextSecondary">
        <item name="totusColorTextTertiary">
        <item name="totusColorTextError">
        <item name="totusColorRipple">
        <item name="totusColorToolbar">
        <item name="totusColorToolbarVariant">
        <item name="totusColorScriptureHighlightFill">
        <item name="totusColorScriptureHighlightStroke">
    </style>

    <style name="Theme.CatholicPrayerBookBy.NoActionBar.Beige" parent="Theme.CatholicPrayerBookBy.NoActionBar">
        <item name="totusColorBgPrimary">
        <item name="totusColorBgSecondary">
        <item name="totusColorSurface">
        <item name="totusColorSurfaceElevated">
        <item name="totusColorSurfaceStroke">
        <item name="totusColorTextPrimary">
        <item name="totusColorTextSecondary">
        <item name="totusColorTextTertiary">
        <item name="totusColorTextError">
        <item name="totusColorRipple">
        <item name="totusColorToolbar">
        <item name="totusColorToolbarVariant">
        <item name="totusColorScriptureHighlightFill">
        <item name="totusColorScriptureHighlightStroke">
        <item name="android:windowBackground">@drawable/bg_gradient_loading_light</item>
    </style>

    <style name="Theme.CatholicPrayerBookBy.Startup" parent="Theme.SplashScreen">
        <item name="totusColorBgPrimary">
        <item name="totusColorBgSecondary">
        <item name="totusColorSurface">
        <item name="totusColorSurfaceElevated">
        <item name="totusColorSurfaceStroke">
        <item name="totusColorTextPrimary">
        <item name="totusColorTextSecondary">
        <item name="totusColorTextTertiary">
        <item name="totusColorTextError">
        <item name="totusColorRipple">
        <item name="totusColorToolbar">
        <item name="totusColorToolbarVariant">
        <item name="totusColorScriptureHighlightFill">
        <item name="totusColorScriptureHighlightStroke">
        <item name="windowSplashScreenBackground">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.CatholicPrayerBookBy.NoActionBar</item>
    </style>

    <style name="Theme.CatholicPrayerBookBy.Startup.Light" parent="Theme.SplashScreen">
        <item name="totusColorBgPrimary">
        <item name="totusColorBgSecondary">
        <item name="totusColorSurface">
        <item name="totusColorSurfaceElevated">
        <item name="totusColorSurfaceStroke">
        <item name="totusColorTextPrimary">
        <item name="totusColorTextSecondary">
        <item name="totusColorTextTertiary">
        <item name="totusColorTextError">
        <item name="totusColorRipple">
        <item name="totusColorToolbar">
        <item name="totusColorToolbarVariant">
        <item name="totusColorScriptureHighlightFill">
        <item name="totusColorScriptureHighlightStroke">
        <item name="windowSplashScreenBackground">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.CatholicPrayerBookBy.NoActionBar.Beige</item>
    </style>

    <style name="Theme.CatholicPrayerBookBy.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="actionButtonStyle">@style/Widget.CatholicPrayerBookBy.Toolbar.ActionButton</item>
    </style>

    <style name="Theme.CatholicPrayerBookBy.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Dark" />

    <style name="Widget.CatholicPrayerBookBy.NavigationView" parent="Widget.MaterialComponents.NavigationView">
        <item name="android:scrollbars">none</item>
        <item name="itemVerticalPadding">14dp</item>
        <item name="itemIconPadding">12dp</item>
    </style>

    <style name="Widget.CatholicPrayerBookBy.RecyclerView" parent="android:Widget">
        <item name="android:scrollbars">none</item>
        <item name="android:fadeScrollbars">true</item>
    </style>

    <style name="Theme.CatholicPrayerBookBy.FullScreenDialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
