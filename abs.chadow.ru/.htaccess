ErrorDocument 404 /404.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Канонизация языка: ?lang=en -> /en/
    RewriteCond %{QUERY_STRING} (^|&)lang=en(&|$) [NC]
    RewriteRule ^$ /en/? [R=301,L]
    RewriteCond %{QUERY_STRING} (^|&)lang=en(&|$) [NC]
    RewriteRule ^([a-z0-9\-]+)/?$ /en/$1/? [R=301,L]

    # Главная: /index.php → / (только при прямом запросе index.php)
    RewriteCond %{THE_REQUEST} \s/+index\.php(?:[?\s]|$) [NC]
    RewriteRule ^index\.php$ / [R=301,L,QSA]

    # SEO: человекочитаемый маршрут sitemap.xml (корень и префикс /en/)
    RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
    RewriteRule ^en/sitemap\.xml$ sitemap.php [L,QSA]

    # Английский роутинг (/en и /en/<slug>)
    # Язык определяется по префиксу /en в includes/lang.php,
    # поэтому не добавляем lang=en в query (иначе копятся дубли при refresh).
    RewriteRule ^en/?$ index.php [L,QSA]
    RewriteRule ^en/([a-z0-9\-]+)/?$ page.php?slug=$1 [L,QSA]

    # Реальные файлы и каталоги (admin/, api/, css/, js/, …) не трогаем
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ЧПУ CMS: /test → page.php?slug=test
    RewriteRule ^([a-z0-9\-]+)/?$ page.php?slug=$1 [L,QSA]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType image/webp "access plus 90 days"
    ExpiresByType image/png "access plus 90 days"
    ExpiresByType image/jpeg "access plus 90 days"
    ExpiresByType image/gif "access plus 90 days"
    ExpiresByType font/woff2 "access plus 180 days"
    ExpiresByType font/woff "access plus 180 days"
    ExpiresByType application/font-woff "access plus 180 days"
    ExpiresByType application/vnd.ms-fontobject "access plus 180 days"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|svg|ico|webp|png|jpe?g|gif|woff2?|eot)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    <FilesMatch "\.(webmanifest)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

<IfModule mod_mime.c>
    AddType image/svg+xml .svg
    AddType application/manifest+json .webmanifest
</IfModule>
