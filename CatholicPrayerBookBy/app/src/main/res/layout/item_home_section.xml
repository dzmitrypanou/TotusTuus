<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginTop="0dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="@dimen/prayer_book_block_gap"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
    app:cardCornerRadius="@dimen/prayer_card_corner"
    app:cardElevation="0dp"
    app:rippleColor="?attr/totusColorRipple"
    app:strokeColor="?attr/totusColorSurfaceStroke"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/image_home_item"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/image_home_item_left_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="14dp"
            android:contentDescription="@null"
            android:visibility="gone"
            app:tint="@android:color/white" />

        <LinearLayout
            android:id="@+id/layout_home_item_center_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/image_home_item_center_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:tint="@android:color/white" />

            <by.dzmitrypanou.catholicapp.ui.TotusToolbarTitleTextView
                android:id="@+id/text_home_item_center_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:lineSpacingExtra="1dp"
                android:maxLines="1"
                android:shadowColor="#E0000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="6"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_home_card_title" />
        </LinearLayout>

        <View
            android:id="@+id/view_home_item_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_home_card_image_scrim" />

        <View
            android:id="@+id/view_home_item_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#994A4A4A"
            android:visibility="gone" />

        <by.dzmitrypanou.catholicapp.ui.TotusToolbarTitleTextView
            android:id="@+id/text_home_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:ellipsize="end"
            android:gravity="start|bottom"
            android:lineSpacingExtra="1dp"
            android:maxLines="2"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingBottom="6dp"
            android:shadowColor="#E0000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_home_card_title" />

        <TextView
            android:id="@+id/text_home_item_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#CC666666"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_home_card_caption"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/button_home_item_info"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_home_info_circle"
            android:contentDescription="@string/home_info_content_description"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_info_black_24dp"
            android:tint="@android:color/white"
            android:visibility="gone" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
