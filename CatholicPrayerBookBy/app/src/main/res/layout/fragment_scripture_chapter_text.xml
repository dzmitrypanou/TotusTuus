<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:scrollbars="none"
    android:paddingStart="@dimen/screen_content_horizontal"
    android:paddingTop="@dimen/prayer_book_screen_padding_top"
    android:paddingEnd="@dimen/screen_content_horizontal"
    android:paddingBottom="@dimen/prayer_book_screen_padding_bottom"
    tools:context=".ui.scripture.ScriptureChapterTextFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_scripture_chapter_body_fallback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/totusColorSurfaceElevated"
            android:lineSpacingExtra="4dp"
            android:padding="@dimen/prayer_card_padding"
            android:textColor="?attr/totusColorTextPrimary"
            android:textSize="@dimen/text_prayer_body"
            android:visibility="gone"
            tools:text="1 Кніга радаводу..." />

        <LinearLayout
            android:id="@+id/layout_scripture_verses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_scripture_chapter_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
            app:cardCornerRadius="@dimen/scripture_chapter_nav_card_radius"
            app:cardElevation="0dp"
            app:strokeColor="?attr/totusColorSurfaceStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/button_scripture_prev_chapter"
                        android:layout_width="@dimen/scripture_chapter_nav_button_size"
                        android:layout_height="@dimen/scripture_chapter_nav_button_size"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/ripple_scripture_chapter_nav_button"
                        android:contentDescription="@string/scripture_prev_chapter_content_description"
                        android:padding="14dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_chevron_left_24"
                        app:tint="@color/scripture_chapter_nav_icon_tint" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_scripture_chapter_picker_trigger"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:contentDescription="@string/scripture_chapter_picker_open_a11y"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/totusColorBgSecondary"
                        app:cardCornerRadius="@dimen/scripture_chapter_nav_button_radius"
                        app:cardElevation="0dp"
                        app:rippleColor="?attr/totusColorRipple"
                        app:strokeColor="?attr/totusColorSurfaceStroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="12dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/text_scripture_chapter_picker_summary"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="?attr/totusColorTextPrimary"
                                android:textSize="16sp"
                                tools:text="Глава 3 з 28" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:contentDescription="@null"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_expand_more_24"
                                app:tint="?attr/totusColorTextSecondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/button_scripture_next_chapter"
                        android:layout_width="@dimen/scripture_chapter_nav_button_size"
                        android:layout_height="@dimen/scripture_chapter_nav_button_size"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/ripple_scripture_chapter_nav_button"
                        android:contentDescription="@string/scripture_next_chapter_content_description"
                        android:padding="14dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/scripture_chapter_nav_icon_tint" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
