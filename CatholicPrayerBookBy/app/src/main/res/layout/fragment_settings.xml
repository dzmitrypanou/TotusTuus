<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:scrollbars="none"
    tools:context=".ui.settings.SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_content_horizontal"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            android:layout_marginEnd="@dimen/screen_content_horizontal"
            app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
            app:cardCornerRadius="@dimen/prayer_card_corner"
            app:cardElevation="0dp"
            app:rippleColor="?attr/totusColorRipple"
            app:strokeColor="?attr/totusColorSurfaceStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/prayer_card_padding"
                android:paddingTop="16dp"
                android:paddingEnd="@dimen/prayer_card_padding"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/settings_text_and_fonts_section_title"
                    android:textColor="?attr/totusColorTextPrimary"
                    android:textSize="@dimen/text_list_row_title"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_font_family_label"
                    android:textColor="?attr/totusColorTextSecondary"
                    android:textSize="@dimen/text_banner_message" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="?attr/totusColorTextSecondary"
                    app:endIconTint="?attr/totusColorTextPrimary"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdown_settings_font_family"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="?attr/totusColorTextPrimary"
                        android:textSize="@dimen/text_banner_message" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/settings_text_and_fonts_section_hint"
                    android:textColor="?attr/totusColorTextSecondary"
                    android:textSize="@dimen/text_banner_message" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/settings_text_preview_label"
                    android:textAllCaps="false"
                    android:textColor="?attr/totusColorTextTertiary"
                    android:textSize="@dimen/text_settings_caption" />

                <TextView
                    android:id="@+id/text_settings_global_preview"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_text_preview_height"
                    android:layout_marginTop="4dp"
                    android:gravity="top"
                    android:lineSpacingExtra="3dp"
                    android:scrollbars="none"
                    android:text="@string/settings_global_text_preview_sample"
                    android:textColor="?attr/totusColorTextPrimary" />

                <TextView
                    android:id="@+id/text_settings_font_percent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_horizontal"
                    android:lineSpacingExtra="2dp"
                    android:textColor="?attr/totusColorTextPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="40%" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:lineSpacingExtra="2dp"
                        android:text="@string/settings_text_size_tap_hint"
                        android:textColor="?attr/totusColorTextSecondary"
                        android:textSize="@dimen/text_banner_message" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_settings_global_text_smaller"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="52dp"
                        android:minHeight="48dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/prayer_text_size_decrease"
                        android:textColor="?attr/totusColorTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:cornerRadius="@dimen/prayer_card_corner"
                        app:rippleColor="?attr/totusColorRipple"
                        app:strokeColor="?attr/totusColorSurfaceStroke"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_settings_global_text_larger"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:minWidth="52dp"
                        android:minHeight="48dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/prayer_text_size_increase"
                        android:textColor="?attr/totusColorTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:cornerRadius="@dimen/prayer_card_corner"
                        app:rippleColor="?attr/totusColorRipple"
                        app:strokeColor="?attr/totusColorSurfaceStroke"
                        app:strokeWidth="1dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_settings_reset_text_defaults"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:letterSpacing="0"
                    android:minHeight="52dp"
                    android:text="@string/settings_reset_text_defaults"
                    android:textAllCaps="false"
                    android:textColor="?attr/totusColorTextPrimary"
                    app:rippleColor="?attr/totusColorRipple"
                    app:strokeColor="?attr/totusColorSurfaceStroke"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_content_horizontal"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            android:layout_marginEnd="@dimen/screen_content_horizontal"
            app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
            app:cardCornerRadius="@dimen/prayer_card_corner"
            app:cardElevation="0dp"
            app:rippleColor="?attr/totusColorRipple"
            app:strokeColor="?attr/totusColorSurfaceStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/prayer_card_padding"
                android:paddingTop="16dp"
                android:paddingEnd="@dimen/prayer_card_padding"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/settings_color_scheme_section_title"
                    android:textColor="?attr/totusColorTextPrimary"
                    android:textSize="@dimen/text_list_row_title"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_settings_color_scheme_dark"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_color_scheme_dark"
                        android:textAllCaps="false"
                        android:textColor="?attr/totusColorTextPrimary"
                        app:rippleColor="?attr/totusColorRipple"
                        app:strokeColor="?attr/totusColorSurfaceStroke"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_settings_color_scheme_light"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/settings_color_scheme_light"
                        android:textAllCaps="false"
                        android:textColor="?attr/totusColorTextPrimary"
                        app:rippleColor="?attr/totusColorRipple"
                        app:strokeColor="?attr/totusColorSurfaceStroke"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_content_horizontal"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            android:layout_marginEnd="@dimen/screen_content_horizontal"
            app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
            app:cardCornerRadius="@dimen/prayer_card_corner"
            app:cardElevation="0dp"
            app:rippleColor="?attr/totusColorRipple"
            app:strokeColor="?attr/totusColorSurfaceStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/prayer_card_padding"
                android:paddingTop="16dp"
                android:paddingEnd="@dimen/prayer_card_padding"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/settings_data_section_title"
                    android:textColor="?attr/totusColorTextPrimary"
                    android:textSize="@dimen/text_list_row_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_settings_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="?attr/totusColorTextSecondary"
                    android:textSize="@dimen/text_banner_message"
                    tools:text="@string/settings_data_hint" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_reset_data"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0"
                    android:minHeight="52dp"
                    android:text="@string/reset_data_and_restart"
                    android:textAllCaps="false"
                    android:textColor="?attr/totusColorTextPrimary"
                    app:rippleColor="?attr/totusColorRipple"
                    app:strokeColor="?attr/totusColorSurfaceStroke"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
