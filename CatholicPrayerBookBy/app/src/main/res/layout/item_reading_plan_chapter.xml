<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/totusColorBgSecondary"
    app:cardCornerRadius="@dimen/reading_plan_chapter_corner"
    app:cardElevation="0dp"
    app:rippleColor="?attr/totusColorRipple"
    app:strokeColor="?attr/totusColorSurfaceStroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="10dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_reading_plan_chapter_accent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_chapter_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="14dp"
            android:paddingTop="16dp"
            android:paddingEnd="8dp"
            android:paddingBottom="16dp"
            android:textColor="?attr/totusColorTextPrimary"
            android:textSize="16sp"
            tools:text="Быццё — глава 1" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_chevron_right_24"
            app:tint="@color/brand_totus_gold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
