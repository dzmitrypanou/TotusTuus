<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_content_horizontal"
    android:paddingTop="@dimen/prayer_book_screen_padding_top"
    android:paddingEnd="@dimen/screen_content_horizontal"
    tools:context=".ui.scripture.ScriptureTranslationsFragment">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_scripture_translation"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/prayer_book_block_gap"
        android:hint="@string/scripture_translation_label"
        app:boxBackgroundColor="?attr/totusColorSurfaceElevated"
        app:boxCornerRadiusBottomEnd="@dimen/prayer_card_corner"
        app:boxCornerRadiusBottomStart="@dimen/prayer_card_corner"
        app:boxCornerRadiusTopEnd="@dimen/prayer_card_corner"
        app:boxCornerRadiusTopStart="@dimen/prayer_card_corner"
        app:boxStrokeColor="?attr/totusColorSurfaceStroke"
        app:endIconMode="dropdown_menu"
        app:endIconTint="?attr/totusColorTextPrimary"
        app:hintTextColor="?attr/totusColorTextSecondary">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/dropdown_scripture_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:dropDownHeight="wrap_content"
            android:dropDownVerticalOffset="4dp"
            android:popupBackground="@drawable/bg_scripture_dropdown_popup"
            android:gravity="center_vertical"
            android:inputType="textNoSuggestions|textMultiLine"
            android:maxLines="6"
            android:minLines="1"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:scrollHorizontally="false"
            android:textColor="?attr/totusColorTextPrimary"
            android:textColorHint="?attr/totusColorTextSecondary"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Уся свабодная вышыня паміж полем перакладу і кнопкай -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/prayer_book_block_gap"
        android:layout_weight="1"
        app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
        app:cardCornerRadius="@dimen/prayer_card_corner"
        app:cardElevation="0dp"
        app:strokeColor="?attr/totusColorSurfaceStroke"
        app:strokeWidth="1dp">

        <ScrollView
            android:id="@+id/scroll_scripture_description"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:fadeScrollbars="false">

            <TextView
                android:id="@+id/text_scripture_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:breakStrategy="simple"
                android:ellipsize="none"
                android:lineSpacingExtra="2dp"
                android:padding="@dimen/prayer_card_padding"
                android:textColor="?attr/totusColorTextSecondary"
                android:textSize="@dimen/text_banner_message"
                tools:text="Кароткае апісанне абранага перакладу." />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/prayer_book_screen_padding_bottom">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_scripture_translation_save_and_return"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:letterSpacing="0"
            android:minHeight="52dp"
            android:text="@string/scripture_translation_save_and_return"
            android:textAllCaps="false"
            android:textColor="?attr/totusColorTextPrimary"
            app:rippleColor="?attr/totusColorRipple"
            app:strokeColor="?attr/totusColorSurfaceStroke"
            app:strokeWidth="1dp" />
    </FrameLayout>
</LinearLayout>
