<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:orientation="vertical"
    android:paddingTop="@dimen/prayer_book_screen_padding_top"
    android:paddingBottom="@dimen/prayer_book_screen_padding_bottom"
    tools:context=".ui.liturgy.LiturgyDayFragment">

    <ScrollView
        android:id="@+id/scroll_liturgy_day"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/prayer_book_block_gap"
            android:paddingTop="@dimen/prayer_book_recycler_padding_top"
            android:paddingEnd="@dimen/prayer_book_block_gap"
            android:paddingBottom="0dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
                app:cardCornerRadius="@dimen/prayer_card_corner"
                app:cardElevation="0dp"
                app:strokeColor="?attr/totusColorSurfaceStroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/prayer_card_padding"
                    android:paddingTop="@dimen/prayer_card_padding"
                    android:paddingEnd="@dimen/prayer_card_padding"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/text_liturgy_day_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="?attr/totusColorTextSecondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layout_liturgy_day_title_rows"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:id="@+id/layout_liturgy_day_readings_sections"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/text_liturgy_day_readings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="11dp"
                        android:includeFontPadding="false"
                        android:textColor="?attr/totusColorTextPrimary"
                        android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
