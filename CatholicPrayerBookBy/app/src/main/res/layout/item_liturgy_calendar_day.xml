<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/liturgy_calendar_day_margin"
    app:cardBackgroundColor="?attr/totusColorBgSecondary"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/totusColorSurfaceStroke"
    app:strokeWidth="1dp">

    <FrameLayout
        android:id="@+id/layout_liturgy_day_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/text_liturgy_day_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/totusColorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/text_liturgy_day_more_star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="3dp"
            android:contentDescription=""
            android:importantForAccessibility="no"
            android:text="*"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>

