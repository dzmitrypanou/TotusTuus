<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingTop="12dp"
    android:paddingEnd="4dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/text_solemnity_group_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="2dp"
        android:textColor="?attr/totusColorTextPrimary"
        android:textStyle="bold"
        tools:text="Абавязковыя святы і ўрачыстасці" />

    <TextView
        android:id="@+id/text_solemnity_group_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lineSpacingExtra="2dp"
        android:textColor="?attr/totusColorTextTertiary"
        android:visibility="gone"
        tools:text="Даты пададзены для 2026 года."
        tools:visibility="visible" />
</LinearLayout>
