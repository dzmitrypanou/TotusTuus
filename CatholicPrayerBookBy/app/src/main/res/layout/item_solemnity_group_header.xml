<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="48dp"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingTop="12dp"
    android:paddingEnd="4dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_solemnity_group_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/totusColorTextPrimary"
            android:textStyle="bold"
            tools:text="Абавязковыя святы і ўрачыстасці" />

        <TextView
            android:id="@+id/text_solemnity_group_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/totusColorTextTertiary"
            android:visibility="gone"
            tools:text="Даты пададзены для 2026 года."
            tools:visibility="visible" />
    </LinearLayout>

    <ImageView
        android:id="@+id/image_solemnity_group_expand"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="12dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_expand_more_24"
        android:tint="?attr/totusColorTextSecondary" />
</LinearLayout>
