<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingTop="@dimen/prayer_book_screen_padding_top"
    android:paddingBottom="@dimen/prayer_book_screen_padding_bottom"
    android:scrollbars="none"
    tools:context=".ui.liturgy.LiturgyCalendarSettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/prayer_book_block_gap"
        android:paddingEnd="@dimen/prayer_book_block_gap"
        android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/prayer_book_block_gap"
            app:cardBackgroundColor="?attr/totusColorSurfaceElevated"
            app:cardCornerRadius="@dimen/prayer_card_corner"
            app:cardElevation="0dp"
            app:strokeColor="?attr/totusColorSurfaceStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/prayer_card_padding">

                <TextView
                    android:id="@+id/text_liturgy_diocese_intro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="12dp"
                    android:text="@string/liturgy_diocese_settings_intro"
                    android:textColor="?attr/totusColorTextSecondary"
                    android:textSize="@dimen/text_list_row_subtitle" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/check_diocese_pinsk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/liturgy_diocese_pinsk"
                    android:textColor="?attr/totusColorTextPrimary" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/check_diocese_minsk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/liturgy_diocese_minsk"
                    android:textColor="?attr/totusColorTextPrimary" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/check_diocese_vitebsk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/liturgy_diocese_vitebsk"
                    android:textColor="?attr/totusColorTextPrimary" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/check_diocese_grodno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/liturgy_diocese_grodno"
                    android:textColor="?attr/totusColorTextPrimary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text_liturgy_calendar_settings_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/liturgy_calendar_settings_note"
            android:textColor="?attr/totusColorTextTertiary"
            android:textSize="@dimen/text_banner_message" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
