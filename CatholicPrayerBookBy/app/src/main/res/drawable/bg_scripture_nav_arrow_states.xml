<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="?attr/totusColorSurface" />
            <stroke
                android:width="1dp"
                android:color="?attr/totusColorSurfaceStroke" />
            <corners android:radius="@dimen/scripture_chapter_nav_button_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/totusColorBgSecondary" />
            <stroke
                android:width="1dp"
                android:color="?attr/totusColorSurfaceStroke" />
            <corners android:radius="@dimen/scripture_chapter_nav_button_radius" />
        </shape>
    </item>
</selector>
