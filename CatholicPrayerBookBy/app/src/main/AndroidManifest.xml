<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".PrayerBookApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.CatholicPrayerBookBy">
        <activity
            android:name=".ui.settings.ResetLoadingActivity"
            android:exported="true"
            android:theme="@style/Theme.CatholicPrayerBookBy.Startup">
        </activity>

        <activity
            android:name=".ui.settings.ResetLoadingDarkActivity"
            android:exported="true"
            android:theme="@style/Theme.CatholicPrayerBookBy.Startup">
        </activity>

        <activity
            android:name=".ui.settings.ResetLoadingLightActivity"
            android:exported="true"
            android:theme="@style/Theme.CatholicPrayerBookBy.Startup.Light">
        </activity>

        <activity
            android:name=".LauncherDark"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_dark"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_dark"
            android:theme="@style/Theme.CatholicPrayerBookBy.Startup">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LauncherLight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_light"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_light"
            android:theme="@style/Theme.CatholicPrayerBookBy.Startup.Light">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CatholicPrayerBookBy.NoActionBar" />

        <activity
            android:name=".MainLightActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CatholicPrayerBookBy.NoActionBar.Beige" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
